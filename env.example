export type DroneStatus = 'Operativo' | 'En misión' | 'Mantenimiento' | 'Inactivo';

export type Drone = {
  id: string;
  nombre: string;
  modelo: string;
  piloto: string;
  base: string;
  autonomiaMin: number;
  bateria: number;
  estado: DroneStatus;
  ultimoVuelo: string;
  horasTotales: number;
};

export type Mission = {
  id: string;
  droneId: string;
  nombre: string;
  zona: string;
  fecha: string;
  estado: 'Planificada' | 'En curso' | 'Completada' | 'Cancelada';
  prioridad: 'Alta' | 'Media' | 'Baja';
};

export type Maintenance = {
  id: string;
  droneId: string;
  tipo: string;
  fecha: string;
  tecnico: string;
  estado: 'Pendiente' | 'En progreso' | 'Completado';
};

export type DashboardPayload = {
  drones: Drone[];
  missions: Mission[];
  maintenance: Maintenance[];
};
